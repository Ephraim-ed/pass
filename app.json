{
  "expo": {
    "name": "PASS",
    "slug": "pass",
    "scheme": "pass",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "PASS uses your photos so you can add player avatars and winner shots.",
          "cameraPermission": "PASS uses the camera to capture the winning moment."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "PASS saves the winner story card to your photo library.",
          "savePhotosPermission": "PASS saves the winner story card to your photo library."
        }
      ]
    ]
  }
}
